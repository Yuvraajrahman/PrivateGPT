# Local dev uses TWO servers (different ports on purpose):
# - OPENAI_BASE_URL (usually :1234/v1) = LM Studio / Ollama — the model only.
# - RAG_BACKEND_URL in web/.env.local (usually :8000) = this repo's FastAPI RAG API.
# Next.js talks to :8000; FastAPI retrieves context then calls :1234 for completions.
# One-command local dev: copy web/.env.local.example → web/.env.local, configure backend/.env,
# start LM Studio on :1234, then from repo root run: npm run dev

# --- Backend (copy to backend/.env or export before uvicorn) ---
# Required: API key for all /v1/* endpoints (and websocket)
RAG_API_KEY=change-me-long-random

# Optional: comma-separated Git host logins stripped from RAG + model output (default in code: Yuvraajrahman).
# Set empty to disable: PRIVATEGPT_REDACT_HANDLES=
# PRIVATEGPT_REDACT_HANDLES=Yuvraajrahman

LLM_PROVIDER=openai_compatible
# LM Studio: Developer tab → Start server (default OpenAI base is often http://127.0.0.1:1234/v1)
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_API_KEY=lm-studio
# Must match LM Studio model id (e.g. google/gemma-4-e4b), see GET http://127.0.0.1:1234/v1/models
CHAT_MODEL=your-loaded-model-name

# Ollama (set LLM_PROVIDER=ollama to use)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

CHROMA_PATH=./data/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Optional Notion sync (POST /v1/notion/sync)
NOTION_TOKEN=
NOTION_PAGE_ID=

# CORS: add your Vercel production URL when hosting the web UI. For local Next on a high port,
# add e.g. http://localhost:3006 here (defaults in config.py cover 3000–3005 if you omit this).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://YOUR-PROJECT.vercel.app

# --- Web (copy to web/.env.local for Next.js proxy) ---
# RAG_BACKEND_URL=http://127.0.0.1:8000
#
# Must match backend RAG_API_KEY (Vercel server-side env)
# RAG_API_KEY=change-me-long-random

# --- Vercel (Production + Preview) server-side env for web/ ---
# RAG_BACKEND_URL = public base URL of FastAPI ONLY (no /v1 path). Example after starting a quick tunnel:
#   cloudflared tunnel --url http://127.0.0.1:8000
#   → use the printed https://....trycloudflare.com value here (tunnel targets uvicorn :8000, NOT LM Studio :1234).
# After cloudflared restarts the hostname changes—update this var and trigger a new deployment.
# RAG_API_KEY = same value as backend RAG_API_KEY
#
# Stable option: Cloudflare named tunnel or ngrok paid reserved domain instead of trycloudflare quick URLs.
#
# CLI: copy web/.env.vercel.secrets.example → web/.env.vercel.secrets, fill values, then from repo root:
#   npm install && npm run vercel:link && npm run vercel:sync-env && npm run vercel:deploy
