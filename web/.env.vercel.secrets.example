# Copy this file to .env.vercel.secrets (same folder). That file is gitignored.
# Then from repo root: npm install && npm run vercel:sync-env
#
# RAG_BACKEND_URL = output of: cloudflared tunnel --url http://127.0.0.1:8000
#   (tunnel FastAPI :8000, not LM Studio :1234). Base URL only, no /v1 path.
RAG_BACKEND_URL=https://REPLACE-ME.trycloudflare.com
#
# Same secret as backend/.env RAG_API_KEY
RAG_API_KEY=REPLACE-ME-LONG-RANDOM
